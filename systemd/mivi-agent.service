[Unit]
Description=Mivi Remote Agent
After=network-online.target usb-keyboard-gadget.service
Requires=usb-keyboard-gadget.service

[Service]
Type=simple

User=admin
WorkingDirectory=/opt/mivi-agent

ExecStartPre=/bin/bash -c 'until [ -e /dev/hidg0 ]; do sleep 1; done'

ExecStart=/opt/mivi-agent/venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8080

Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target